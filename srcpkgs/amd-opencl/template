do_fetch() {
    for i in "${!_debs[@]}"; do
        file="${_debs[i]##*/}"
        xbps-fetch -o "$file" "${_debs[i]}"

        if ! echo "${_checksums[i]}  $file" | sha256sum -c -; then
            echo "error: invalid checksum" >&2
            return 1
        fi
    done
}

do_install() {
    cd "$XBPS_BUILDDIR"

    for pkg in *.deb; do
        ar -x "$pkg"

        if [[ -f data.tar.gz ]]; then
            tar -xzf data.tar.gz
            rm data.tar.gz
        elif [[ -f data.tar.xz ]]; then
            tar -xJf data.tar.xz
            rm data.tar.xz
        elif [[ -f data.tar.zst ]]; then
            tar --use-compress-program=unzstd -xf data.tar.zst
            rm data.tar.zst
        fi

        rm -f debian-binary control.tar.gz
    done

    mv opt "$DESTDIR/opt"
    mv "$DESTDIR/opt/rocm-$version" "$DESTDIR/opt/rocm"

    mkdir -p "$DESTDIR/opt/amdgpu/share/libdrm"
    ln -s /usr/share/libdrm/amdgpu.ids "$DESTDIR/opt/amdgpu/share/libdrm/amdgpu.ids"

    mkdir -p "$DESTDIR/etc/OpenCL/vendors"
    echo /opt/rocm/lib/libamdocl64.so > "$DESTDIR/etc/OpenCL/vendors/amdocl64.icd"

    mkdir -p "$DESTDIR/etc/ld.so.conf.d"
    echo /opt/rocm/lib >> "$DESTDIR/etc/ld.so.conf.d/opencl-amd.conf"
    echo /opt/rocm/hip/lib >> "$DESTDIR/etc/ld.so.conf.d/opencl-amd.conf"

    mkdir -p "$DESTDIR/etc/profile.d"
    echo 'export PATH="${PATH}:/opt/rocm/bin:/opt/rocm/hip/bin"' > "$DESTDIR/etc/profile.d/opencl-amd.sh"
}
